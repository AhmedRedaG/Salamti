{
  "name": "salamti",
  "version": "0.0.1",
  "description": "Intelligent Vehicle Accident Response System",
  "author": "Ahmed Reda",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "pnpm run db:gen && nest build",
    "start": "pnpm run db:gen && nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main.js",
    "db:gen": "pnpm prisma generate",
    "db:push": "pnpm prisma db push",
    "db:seed": "pnpm prisma db seed",
    "db:meg": "pnpm prisma migrate dev --create-only",
    "db:megdev": "pnpm prisma migrate dev",
    "db:megprod": "pnpm prisma migrate deploy",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix"
  },
  "dependencies": {
    "@getbrevo/brevo": "^5.0.4",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.18",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.18",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.1.1",
    "@nestjs/microservices": "^11.1.19",
    "@nestjs/platform-express": "^11.1.18",
    "@nestjs/platform-socket.io": "^11.1.19",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.19",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.73.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cloudinary": "^2.9.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "ejs": "^5.0.2",
    "firebase-admin": "^13.8.0",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.1.0",
    "mqtt": "^5.15.1",
    "multer": "^2.1.1",
    "nestjs-pino": "^4.6.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3",
    "streamifier": "^0.1.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.19",
    "@nestjs/schematics": "^11.0.10",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.6",
    "@types/helmet": "^4.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "@types/streamifier": "^0.1.2",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.5.0",
    "prettier": "^3.8.2",
    "prisma": "^7.7.0",
    "source-map-support": "^0.5.21",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
